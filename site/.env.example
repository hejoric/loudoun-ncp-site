# Keystatic GitHub Mode (optional)
# Required only if you want to use the web-based CMS editor in production.
# Without these, the site builds and deploys as a fully static site with no
# online editor. Content is edited locally by running `npm run dev`.
#
# To enable:
# 1. Create a GitHub OAuth App at https://github.com/settings/applications/new
#    - Authorization callback URL: https://loudounnatureconservation.org/api/keystatic/github/oauth/callback
# 2. Create a Keystatic app secret: openssl rand -hex 32
# 3. Set these variables in Cloudflare Pages environment settings
# 4. Also update astro.config.mjs and wrangler.toml (see README)

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
KEYSTATIC_GITHUB_REPO_OWNER=
KEYSTATIC_GITHUB_REPO_NAME=loudoun-ncp
