---
interface Props {
  title: string;
  authors: string[];
  date: string;
  abstract: string;
  slug: string;
  pdfFile?: string | null;
  pdfLink?: string | null;
}

const { title, authors, date, abstract, slug, pdfFile, pdfLink } = Astro.props;
const pdfHref = pdfFile ?? pdfLink;
const displayDate = date ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) : '';
const preview = abstract.length > 160 ? abstract.slice(0, 157) + '…' : abstract;
---

<article class="bg-paper border hairline p-7 flex flex-col gap-3 hover:border-forest-800 transition-colors">
  <div>
    <p class="text-xs font-semibold text-clay uppercase tracking-wider mb-2">{displayDate}</p>
    <h3 class="font-display font-medium text-ink text-xl leading-snug">
      <a href={`/research/${slug}/`} class="hover:text-forest-900 transition-colors">
        {title}
      </a>
    </h3>
    <p class="text-sm text-ink-soft mt-1">{authors.join(', ')}</p>
  </div>
  <p class="text-sm text-ink-soft leading-relaxed flex-1">{preview}</p>
  <div class="flex items-center gap-5 mt-auto pt-4 border-t hairline">
    <a
      href={`/research/${slug}/`}
      class="text-sm text-ink border-b border-ink pb-0.5 hover:text-ink-soft hover:border-ink-soft transition-colors"
    >
      Read more
    </a>
    {pdfHref && (
      <a
        href={pdfHref}
        class="text-sm font-medium text-ink-soft hover:text-ink transition-colors flex items-center gap-1"
        target="_blank"
        rel="noopener noreferrer"
        download={pdfFile ? true : undefined}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        PDF
      </a>
    )}
  </div>
</article>
