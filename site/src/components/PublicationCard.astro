---
interface Props {
  title: string;
  authors: string[];
  date: string;
  abstract: string;
  slug: string;
  pdfFile?: string | null;
  pdfLink?: string | null;
}

const { title, authors, date, abstract, slug, pdfFile, pdfLink } = Astro.props;
const pdfHref = pdfFile ?? pdfLink;
const displayDate = date ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) : '';
const preview = abstract.length > 160 ? abstract.slice(0, 157) + '…' : abstract;
---

<article class="bg-white rounded-xl border border-gray-200 p-6 flex flex-col gap-3 hover:border-[#40916C] hover:shadow-md transition-all">
  <div>
    <p class="text-xs font-semibold text-[#40916C] uppercase tracking-wide mb-1">{displayDate}</p>
    <h3 class="font-display font-bold text-[#1c2b22] text-base leading-snug">
      <a href={`/research/${slug}/`} class="hover:text-[#2D6A4F] transition-colors">
        {title}
      </a>
    </h3>
    <p class="text-sm text-gray-500 mt-1">{authors.join(', ')}</p>
  </div>
  <p class="text-sm text-gray-600 leading-relaxed flex-1">{preview}</p>
  <div class="flex items-center gap-3 mt-auto pt-3 border-t border-gray-100">
    <a
      href={`/research/${slug}/`}
      class="text-sm font-medium text-[#2D6A4F] hover:text-[#1B4332] transition-colors"
    >
      Read more
    </a>
    {pdfHref && (
      <a
        href={pdfHref}
        class="text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors flex items-center gap-1"
        target="_blank"
        rel="noopener noreferrer"
        download={pdfFile ? true : undefined}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        PDF
      </a>
    )}
  </div>
</article>
