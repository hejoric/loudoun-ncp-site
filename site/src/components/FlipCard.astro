---
import InitialsAvatar from './InitialsAvatar.astro';

interface Props {
  name: string;
  role: string;
  bio: string;
  headshot?: string | null;
  headshotPosition?: string | null;
  headshotScale?: string | null;
  email?: string | null;
  instagram?: string | null;
  linkedin?: string | null;
  website?: string | null;
  accentColor?: string;
  avatarSize?: string;
}

const {
  name,
  role,
  bio,
  headshot,
  headshotPosition,
  headshotScale,
  email,
  instagram,
  linkedin,
  website,
  accentColor = '#1B4332',
  avatarSize = 'w-10 h-10',
} = Astro.props;

const slug = name.toLowerCase().replace(/\s+/g, '-');
const focalPoint = headshotPosition || 'top';
const scale = Number(headshotScale) || 1;
---

<div
  class="card-flip w-full h-80 cursor-pointer"
  tabindex="0"
  role="button"
  aria-label={`View ${name}'s profile`}
  aria-pressed="false"
  data-card-flip
>
  <div class="card-flip-inner">
    <!-- Front -->
    <div class="card-flip-front flex flex-col bg-paper border hairline">
      <!-- Headshot -->
      <div class="flex-1 relative overflow-hidden bg-gray-100">
        {headshot ? (
          <img
            src={headshot}
            alt={`${name} headshot`}
            class="absolute inset-0 w-full h-full object-cover"
            style={`object-position:${focalPoint};${scale !== 1 ? ` transform:scale(${scale}); transform-origin:center bottom;` : ''}`}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center">
            <InitialsAvatar name={name} size="xl" bgColor={accentColor} />
          </div>
        )}
      </div>
      <!-- Name + role -->
      <div class="p-3 text-center" style={`background:${accentColor};`}>
        <p class="font-display font-bold text-white text-sm leading-tight">{name}</p>
        <p class="text-white/80 text-xs mt-0.5">{role}</p>
      </div>
    </div>

    <!-- Back -->
    <div
      class="card-flip-back flex flex-col p-4 bg-paper border hairline"
    >
      <!-- Header band + small avatar -->
      <div class="flex items-center gap-2 pb-3 border-b border-gray-100" style={`border-color:${accentColor}33;`}>
        <div class={`${avatarSize} rounded-full overflow-hidden shrink-0`} style={`background:${accentColor};`}>
          {headshot ? (
            <img
              src={headshot}
              alt=""
              class="w-full h-full object-cover"
              style={`object-position:${headshotPosition || 'top'};`}
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
          ) : (
            <InitialsAvatar name={name} size="sm" bgColor={accentColor} />
          )}
        </div>
        <div>
          <p class="font-display font-bold text-[#1c2b22] text-xs leading-tight">{name}</p>
          <p class="text-gray-500 text-xs">{role}</p>
        </div>
      </div>

      <!-- Bio -->
      <p class="text-xs text-gray-600 leading-relaxed flex-1 mt-3 overflow-y-auto">{bio || 'Bio coming soon.'}</p>

      <!-- Social icons -->
      {(email || instagram || linkedin || website) && (
        <div class="flex items-center gap-3 mt-3 pt-3 border-t border-gray-100">
          {email && (
            <a
              href={`mailto:${email}`}
              class="text-gray-400 hover:text-[#1B4332] transition-colors"
              aria-label={`Email ${name}`}
              onclick="event.stopPropagation()"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </a>
          )}
          {instagram && (
            <a
              href={`https://instagram.com/${instagram}`}
              class="text-gray-400 hover:text-[#1B4332] transition-colors"
              aria-label={`${name} on Instagram`}
              target="_blank"
              rel="noopener noreferrer"
              onclick="event.stopPropagation()"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd"/>
              </svg>
            </a>
          )}
          {linkedin && (
            <a
              href={linkedin}
              class="text-gray-400 hover:text-[#1B4332] transition-colors"
              aria-label={`${name} on LinkedIn`}
              target="_blank"
              rel="noopener noreferrer"
              onclick="event.stopPropagation()"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
          {website && (
            <a
              href={website}
              class="text-gray-400 hover:text-[#1B4332] transition-colors"
              aria-label={`${name}'s personal website`}
              target="_blank"
              rel="noopener noreferrer"
              onclick="event.stopPropagation()"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-9c2.5 2.5 3.5 6 3.5 9s-1 6.5-3.5 9c-2.5-2.5-3.5-6-3.5-9s1-6.5 3.5-9zM3.5 12h17"/>
              </svg>
            </a>
          )}
        </div>
      )}

      <!-- Screen-reader bio (always in DOM for SEO) -->
      <span class="sr-only">{name}, {role}. {bio}</span>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('[data-card-flip]').forEach((card) => {
    const el = card as HTMLElement;
    const toggle = () => {
      const flipped = el.classList.toggle('is-flipped');
      el.setAttribute('aria-pressed', String(flipped));
    };
    el.addEventListener('click', toggle);
    el.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'Enter' || ke.key === ' ') {
        ke.preventDefault();
        toggle();
      }
    });
  });
</script>
