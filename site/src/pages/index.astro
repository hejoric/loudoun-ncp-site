---
import Base from '@/layouts/Base.astro';
import FlipCard from '@/components/FlipCard.astro';
import reader from '@/lib/reader';

const home = await reader.singletons.home.read();
const allTeam = await reader.collections.teamMembers.all();
const featuredTeam = allTeam
  .filter((m) => m.entry.featuredOnHome)
  .sort((a, b) => (a.entry.sortOrder ?? 99) - (b.entry.sortOrder ?? 99));
const ryan = allTeam.find((m) => m.slug === 'ryan-nisay') ?? null;

// Accept any YouTube reference an editor might paste (full watch URL, youtu.be
// share link with tracking params, embed/shorts URL, or a bare ID) and reduce
// it to the 11-character video ID. Returns '' if nothing usable is found, in
// which case the spotlight falls back to a thumbnail that links to the article.
function youtubeId(raw: string | null | undefined): string {
  const s = (raw ?? '').trim();
  if (!s) return '';
  if (/^[\w-]{11}$/.test(s)) return s;
  const m =
    s.match(/(?:v=|\/embed\/|\/shorts\/|youtu\.be\/)([\w-]{11})/) ??
    s.match(/([\w-]{11})/);
  return m ? m[1] : '';
}

// A "&t=90" / "&t=90s" / "&start=90" in the pasted URL sets where playback
// begins (it does not affect the poster thumbnail). Returns 0 when absent.
function youtubeStart(raw: string | null | undefined): number {
  const m = (raw ?? '').match(/[?&](?:t|start)=(\d+)/);
  return m ? parseInt(m[1], 10) : 0;
}

// Spotlight: featured WUSA video + highlight cards. Values come from the home
// singleton with hardcoded fallbacks so the section renders even before an
// editor fills them in. A blank video ID falls back to a thumbnail that links
// out to the article.
const spotlight = {
  videoId: youtubeId(home?.spotlightVideoId),
  videoStart: youtubeStart(home?.spotlightVideoId),
  videoTitle: home?.spotlightVideoTitle || 'These local students are cleaning up parks in Northern Virginia',
  videoSource: home?.spotlightVideoSource || 'WUSA9',
  videoUrl:
    home?.spotlightVideoUrl ||
    'https://www.wusa9.com/video/tech/science/environment/these-local-students-are-cleaning-up-parks-in-northern-virginia/65-71e16312-f011-4edf-a3b5-fb93d8432e6e',
  items:
    (home?.spotlightItems?.length ? home.spotlightItems : null) ?? [
      {
        label: '2025 Award',
        title: 'Winner, Environmental Excellence Award',
        body:
          "The Loudoun County Environmental Commission named LNCP founder Ryan Nisay, a Potomac Falls High School senior, the 2025 Student winner of its Environmental Excellence Award, recognizing the project for encouraging young people to take action in environmental restoration.",
        linkText: 'Read the news release (PDF)',
        linkUrl: '/assets/lncp-environmental-excellence-award-2025.pdf',
        secondaryLinkText: '',
        secondaryLinkUrl: '',
      },
      {
        label: 'Recognition',
        title: 'Honored in the U.S. Congressional Record',
        body:
          "LNCP was honored in the U.S. Congressional Record by Representative Suhas Subramanyam of Virginia's 10th Congressional District, recognizing a student-led effort now more than 270 members strong.",
        linkText: 'Read the entry on Congress.gov',
        linkUrl:
          'https://www.congress.gov/congressional-record/volume-172/issue-115/extensions-of-remarks-section/article/E694-2',
        secondaryLinkText: 'View the record (PDF)',
        secondaryLinkUrl: '/assets/lncp-congressional-record.pdf',
      },
      {
        label: 'In the community',
        title: 'A five-hour cleanup with Keep Loudoun Beautiful',
        body:
          'On April 12, LNCP collaborated with Keep Loudoun Beautiful to host a large-scale cleanup in Leesburg, Virginia, gathering an astonishing amount of trash over five hours of work.',
        linkText: 'See the post on LinkedIn',
        linkUrl:
          'https://www.linkedin.com/posts/loudoun-nature-conservation-project_on-april-12-our-organization-was-able-to-activity-7451375612444868608-Qht7',
        secondaryLinkText: '',
        secondaryLinkUrl: '',
      },
    ],
};
// A real still from the WUSA segment (dropped in by an editor) makes the best
// poster and is guaranteed to exist, unlike YouTube's maxres thumbnail which
// 404s for some videos. Falls back to a cleanup photo if the still is missing.
const spotlightPoster = '/assets/wusa-spotlight-poster.jpg';

// Split the hero headline on the semicolon so it renders on two lines.
const heroHeadline = home?.heroHeadline ?? 'Youth unite for Earth; inspire change piece by piece';
const heroHeadlineParts = heroHeadline.split(';').map((p) => p.trim()).filter(Boolean);

const stats = [
  { value: home?.statsAcresCleaned?.toLocaleString() ?? '3,122', label: 'Acres Cleaned' },
  { value: home?.statsMembers?.toLocaleString() ?? '270', label: 'Members' },
  { value: home?.statsImpressions?.toLocaleString() ?? '726,022', label: 'Impressions' },
  { value: home?.statsPartners?.toLocaleString() ?? '17', label: 'Partner Parks & Schools' },
];

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Loudoun Nature Conservation Project',
  url: 'https://loudounnatureconservation.org',
  logo: 'https://loudounnatureconservation.org/assets/lncp-logo.png',
  foundingDate: '2024',
  description: 'A student-led 501(c)(3) nonprofit advancing sustainability and ecological health across Loudoun County, Virginia.',
  email: 'directors@loudounnatureconservation.org',
};
---

<Base
  title="Home"
  description="Loudoun Nature Conservation Project - A student-led 501(c)(3) nonprofit empowering youth, restoring nature, and fostering community through environmental stewardship in Loudoun County, Virginia."
  jsonLd={orgJsonLd}
>
  <!-- Announcement: back for the new school year -->
  <a
    href="/team/#branches"
    class="block bg-forest-900 text-paper text-center text-sm px-4 py-2.5 hover:bg-forest-800 transition-colors"
  >
    We're coming back, Loudoun. New school branches announced for the upcoming year
    <span aria-hidden="true">&rarr;</span>
  </a>

  <!-- Hero: editorial headline over a full-bleed background video -->
  <section class="bg-paper pb-16 sm:pb-24" aria-label="Hero">
    <div class="relative overflow-hidden border-b hairline bg-forest-950">
      <!-- Background video: spans the full page width; the even scrim keeps text legible -->
      <video
        id="hero-video"
        class="absolute inset-0 w-full h-full object-cover pointer-events-none motion-reduce:hidden"
        autoplay
        muted
        loop
        playsinline
        poster="/assets/hero-poster.jpg"
        aria-hidden="true"
      >
        <source src="/assets/hero.mp4" type="video/mp4" />
      </video>
      <!-- Even scrim: uniform brand-tinted darkening for consistent legibility -->
      <div class="absolute inset-0 bg-forest-950/55 pointer-events-none"></div>

      <div class="relative z-10 flex items-center justify-center min-h-[560px] sm:min-h-[70vh]">
        <div class="max-w-3xl mx-auto px-6 sm:px-10 py-20 sm:py-28 text-center">
          <p class="font-display italic text-[#F0A878] text-lg sm:text-xl [text-shadow:0_1px_2px_rgba(13,33,24,0.9),0_2px_18px_rgba(13,33,24,0.55)]">Loudoun County, Virginia</p>
          <h1 class="font-display font-medium text-4xl sm:text-6xl lg:text-7xl leading-[1.06] tracking-tight text-paper mt-6 mb-8 text-balance">
            {heroHeadlineParts.map((part, i) => (
              <span class="block">{part}{i < heroHeadlineParts.length - 1 ? ';' : ''}</span>
            ))}
          </h1>
          <p class="text-base sm:text-lg text-paper/80 max-w-2xl mx-auto mb-10 leading-relaxed">
            {home?.heroSubtext ?? 'Made by Students, for Students. Young hearts, green minds, hands-on action - empowering youth, restoring nature, and fostering community through non-profit (501c3) environmental stewardship in Loudoun County, Virginia.'}
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
            <a
              href="/volunteer/"
              class="px-8 py-4 font-semibold text-sm bg-paper text-forest-900 hover:bg-paper-2 transition-colors"
            >
              Join Now
            </a>
            <a
              href="/about/"
              class="text-sm text-paper border-b border-paper/60 pb-0.5 hover:border-paper transition-colors"
            >
              Read our story
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Founder quote: italic serif pull-quote -->
  {ryan && (
    <section class="bg-paper pb-24" aria-label="A word from our founder">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <blockquote class="font-display italic font-medium text-2xl sm:text-3xl leading-snug text-ink text-balance">
          &ldquo;{home?.founderQuote ?? "LNCP was born from a simple belief - students don't have to wait to protect our environment. We can lead that change right now, in our own community."}&rdquo;
        </blockquote>
        <div class="flex items-center justify-center gap-3 mt-8">
          {ryan.entry.headshot && (
            <img
              src={ryan.entry.headshot}
              alt={ryan.entry.name}
              width="44"
              height="44"
              class="w-11 h-11 rounded-full object-cover"
              loading="lazy"
            />
          )}
          <div class="text-left">
            <p class="text-sm font-semibold text-ink">{ryan.entry.name}</p>
            <p class="text-xs text-ink-soft">{ryan.entry.role}</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Spotlight: featured WUSA video + highlight cards -->
  <section class="bg-paper pb-24" aria-labelledby="spotlight-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Spotlight</p>
        <h2 id="spotlight-heading" class="font-display font-medium text-3xl sm:text-4xl text-ink">In the spotlight</h2>
        <p class="text-ink-soft mt-4 text-base leading-relaxed">
          The moments and milestones defining our work - from the evening news to the halls of Congress.
        </p>
      </div>

      <!-- Featured video -->
      <figure class="m-0">
        {spotlight.videoId ? (
          <div
            data-yt-facade
            data-yt-id={spotlight.videoId}
            data-yt-start={spotlight.videoStart ? String(spotlight.videoStart) : undefined}
            data-yt-title={spotlight.videoTitle}
            role="button"
            tabindex="0"
            aria-label={`Play video: ${spotlight.videoTitle}`}
            class="group relative block w-full aspect-video overflow-hidden border hairline bg-forest-950 cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-clay focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
          >
            <img
              src={spotlightPoster}
              alt={spotlight.videoTitle}
              width="1280"
              height="720"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-forest-950/25 group-hover:bg-forest-950/15 transition-colors"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="flex items-center justify-center w-20 h-20 rounded-full bg-paper/95 shadow-lg transition-transform duration-300 group-hover:scale-110">
                <svg class="w-8 h-8 text-forest-900 translate-x-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              </span>
            </div>
          </div>
        ) : (
          <a
            href={spotlight.videoUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Watch on ${spotlight.videoSource}: ${spotlight.videoTitle} (opens in a new tab)`}
            class="group relative block w-full aspect-video overflow-hidden border hairline bg-forest-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-clay focus-visible:ring-offset-2 focus-visible:ring-offset-paper"
          >
            <img
              src={spotlightPoster}
              alt={spotlight.videoTitle}
              width="1440"
              height="810"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-forest-950/80 via-forest-950/30 to-forest-950/20"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="flex items-center justify-center w-20 h-20 rounded-full bg-paper/95 shadow-lg transition-transform duration-300 group-hover:scale-110">
                <svg class="w-8 h-8 text-forest-900 translate-x-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              </span>
            </div>
            <div class="absolute left-0 right-0 bottom-0 p-6 sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-widest text-paper/80">Watch on {spotlight.videoSource}</p>
              <p class="font-display text-paper text-lg sm:text-2xl leading-snug mt-2 max-w-2xl text-balance">{spotlight.videoTitle}</p>
            </div>
          </a>
        )}
        <figcaption class="text-xs uppercase tracking-wider text-ink-soft mt-3">
          {spotlight.videoSource} · {spotlight.videoTitle}
        </figcaption>
      </figure>

      <!-- Highlight cards -->
      <div class="grid md:grid-cols-3 border-t border-l hairline mt-14">
        {spotlight.items.map((item) => (
          <div class="border-r border-b hairline p-8 flex flex-col bg-paper-2">
            <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-4">{item.label}</p>
            <h3 class="font-display font-medium text-xl leading-snug text-ink text-balance">{item.title}</h3>
            <p class="text-sm text-ink-soft leading-relaxed mt-3 flex-1">{item.body}</p>
            {(item.linkUrl || item.secondaryLinkUrl) && (
              <div class="flex flex-wrap gap-x-6 gap-y-2 mt-6">
                {item.linkUrl && item.linkText && (
                  <a
                    href={item.linkUrl}
                    class="text-sm text-ink border-b border-ink pb-0.5 hover:text-ink-soft hover:border-ink-soft transition-colors"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {item.linkText}
                  </a>
                )}
                {item.secondaryLinkUrl && item.secondaryLinkText && (
                  <a
                    href={item.secondaryLinkUrl}
                    class="text-sm text-ink border-b border-ink pb-0.5 hover:text-ink-soft hover:border-ink-soft transition-colors"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {item.secondaryLinkText}
                  </a>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mission: two-column editorial -->
  <section class="bg-paper border-t hairline py-24" aria-labelledby="mission-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-[0.9fr_1.3fr] gap-10 md:gap-20 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Conservation</p>
        <h2 id="mission-heading" class="font-display font-medium text-2xl sm:text-3xl leading-snug text-ink text-balance">
          {home?.missionHeading ?? 'The deliberate act of preserving, protecting, and restoring our natural environment for the benefit of future generations.'}
        </h2>
      </div>
      <div>
        <p class="text-base sm:text-lg text-ink-soft leading-relaxed">
          {home?.missionBody ?? 'Loudoun Nature Conservation Project is a student-led nonprofit working to advance sustainability and ecological health across Loudoun County. We engage our community through education, hands-on restoration, and advocacy, empowering young people to become lifelong stewards of the environment.'}
        </p>
        <a
          href="/about/"
          class="inline-block mt-7 text-sm text-ink border-b border-ink pb-0.5 hover:text-ink-soft hover:border-ink-soft transition-colors"
        >
          Learn more about our mission
        </a>
      </div>
    </div>
  </section>

  <!-- Stats: hairline grid -->
  <section class="bg-paper pb-24" aria-label="Impact statistics">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <dl class="grid grid-cols-2 lg:grid-cols-4 border-t border-l hairline">
        {stats.map(({ value, label }) => (
          <div class="border-r border-b hairline p-6 sm:p-9">
            <dt class="sr-only">{label}</dt>
            <dd class="font-display text-3xl sm:text-5xl text-forest-900">{value}</dd>
            <dd class="text-xs uppercase tracking-wider text-ink-soft mt-2">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Field gallery: scroll-expand photos -->
  <section class="bg-paper pb-24" aria-label="In the field">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      <figure data-scroll-expand class="m-0">
        <img
          src="/assets/large-group-cleanup.jpg"
          alt="A large group of LNCP student volunteers gathered after a park cleanup"
          width="1440"
          height="1085"
          class="w-full object-cover border hairline"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="text-xs uppercase tracking-wider text-ink-soft mt-3">
          Student volunteers after a Loudoun County park cleanup
        </figcaption>
      </figure>
      <figure data-scroll-expand class="m-0">
        <img
          src="/assets/8-people-cleanup-done.jpg"
          alt="LNCP volunteers with collected trash bags at the end of a cleanup"
          width="2048"
          height="1536"
          class="w-full object-cover border hairline"
          loading="lazy"
          decoding="async"
        />
        <figcaption class="text-xs uppercase tracking-wider text-ink-soft mt-3">
          Bags collected, piece by piece
        </figcaption>
      </figure>
      <div class="grid sm:grid-cols-2 gap-6 sm:gap-8">
        <figure class="m-0">
          <img
            src="/assets/outdoor7peoplecrew.jpg"
            alt="An LNCP cleanup crew posing together outdoors"
            width="1600"
            height="2133"
            class="w-full h-105 object-cover border hairline"
            loading="lazy"
            decoding="async"
          />
          <figcaption class="text-xs uppercase tracking-wider text-ink-soft mt-3">
            Crew day in the field
          </figcaption>
        </figure>
        <figure class="m-0">
          <img
            src="/assets/outdoor3people.jpg"
            alt="Three LNCP volunteers working outdoors"
            width="1440"
            height="1080"
            class="w-full h-105 object-cover border hairline"
            loading="lazy"
            decoding="async"
          />
          <figcaption class="text-xs uppercase tracking-wider text-ink-soft mt-3">
            Hands-on restoration
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Featured Team -->
  {featuredTeam.length > 0 && (
    <section class="bg-paper border-t hairline py-24" aria-labelledby="team-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mb-14">
          <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Meet Our Team</p>
          <h2 id="team-heading" class="font-display font-medium text-3xl sm:text-4xl text-ink">Leading Staff</h2>
          <p class="text-ink-soft mt-4 text-base leading-relaxed">
            Our staff is made up of passionate student leaders dedicated to environmental advocacy and community engagement. Hover or tap a card to learn more.
          </p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
          {featuredTeam.map((member) => (
            <FlipCard
              name={member.entry.name}
              role={member.entry.role}
              bio={member.entry.bio}
              headshot={member.entry.headshot}
              email={member.entry.email ?? undefined}
              instagram={member.entry.instagram ?? undefined}
              linkedin={member.entry.linkedin ?? undefined}
              website={member.entry.website ?? undefined}
              affiliationLogo={member.entry.affiliationLogo ?? undefined}
              affiliation={member.entry.affiliation ?? undefined}
              accentColor="#1B4332"
            />
          ))}
        </div>
        <div class="mt-12">
          <a
            href="/team/"
            class="text-sm text-ink border-b border-ink pb-0.5 hover:text-ink-soft hover:border-ink-soft transition-colors"
          >
            View the full team
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Press -->
  <section class="bg-paper border-t hairline py-16" aria-labelledby="press-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="press-heading" class="text-xs font-semibold uppercase tracking-widest text-ink-soft text-center mb-10">
        News on Loudoun Nature Conservation Project
      </h2>
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
        {(home?.pressLinks ?? [
          { publication: 'WTOP', headline: 'Still in high school, Loudoun County students look to clean up the environment for future generations', url: 'https://wtop.com/loudoun-county/2024/11/still-in-high-school-loudon-county-students-look-to-clean-up-the-environment-for-future-generations/' },
          { publication: 'Loudoun Now', headline: 'Sterling teens create conservation nonprofit, offer weekly park cleanups', url: 'https://www.loudounnow.com/giving_back/sterling-teens-create-conservation-nonprofit-offer-weekly-park-cleanups/article_f54fbbc6-777a-11ef-a63e-a7c6205f9ce0.html' },
          { publication: 'InsideNOVA', headline: 'Loudoun high school students are trying to clean up the environment for future generations', url: 'https://www.insidenova.com/headlines/loudoun-high-school-students-are-trying-to-clean-up-the-environment-for-future-generations/article_c7e18406-a369-11ef-a330-23b6f26e801e.html' },
          { publication: 'U.S. Congressional Record', headline: 'Recognizing the Loudoun Nature Conservation Project', url: 'https://www.congress.gov/congressional-record/volume-172/issue-115/extensions-of-remarks-section/article/E694-2' },
        ]).map((link) => (
          <a
            href={link.url}
            class="font-display text-xl sm:text-2xl text-ink hover:text-clay transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            title={link.headline}
          >
            {link.publication}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-forest-900 py-24 text-center" aria-labelledby="cta-heading">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 id="cta-heading" class="font-display font-medium text-3xl sm:text-4xl text-paper mb-5 text-balance">
        Ready to make a difference?
      </h2>
      <p class="text-paper/70 text-base mb-10">
        Join hundreds of students already protecting Loudoun County's natural spaces. Volunteer, collaborate, or reach out.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a
          href="/volunteer/"
          class="px-8 py-4 font-semibold text-sm bg-paper text-forest-900 hover:bg-paper-2 transition-colors"
        >
          Volunteer Now
        </a>
        <a
          href="/contact/"
          class="text-sm text-paper border-b border-paper/60 pb-0.5 hover:border-paper transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Base>

<script>
  // Spotlight video: lazy YouTube facade. We render a thumbnail + play button
  // and only inject the heavy iframe once the visitor chooses to play, keeping
  // the initial page fast and avoiding YouTube cookies until intent is clear.
  const facade = document.querySelector<HTMLElement>('[data-yt-facade]');
  if (facade) {
    const play = () => {
      const id = facade.dataset.ytId;
      if (!id) return;
      const title = facade.dataset.ytTitle ?? 'Video';
      const iframe = document.createElement('iframe');
      iframe.className = 'absolute inset-0 w-full h-full';
      const start = facade.dataset.ytStart ? `&start=${facade.dataset.ytStart}` : '';
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0${start}`;
      iframe.title = title;
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      facade.replaceChildren(iframe);
      facade.classList.remove('cursor-pointer', 'group');
      iframe.focus();
    };
    facade.addEventListener('click', play);
    facade.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        play();
      }
    });
  }

  const expandEls = document.querySelectorAll<HTMLElement>('[data-scroll-expand]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (expandEls.length > 0 && !reduced) {
    let ticking = false;
    const update = () => {
      ticking = false;
      const vh = window.innerHeight;
      expandEls.forEach((el) => {
        const rect = el.getBoundingClientRect();
        const progress = Math.min(1, Math.max(0, (vh - rect.top) / (vh * 0.85)));
        el.style.setProperty('--expand', progress.toFixed(3));
      });
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    update();
  }
</script>
