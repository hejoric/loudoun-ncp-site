---
import Base from '@/layouts/Base.astro';
import FlipCard from '@/components/FlipCard.astro';
import InitialsAvatar from '@/components/InitialsAvatar.astro';
import reader from '@/lib/reader';

const home = await reader.singletons.home.read();
const allTeam = await reader.collections.teamMembers.all();
const featuredTeam = allTeam
  .filter((m) => m.entry.featuredOnHome)
  .sort((a, b) => a.entry.sortOrder - b.entry.sortOrder);
const ryan = allTeam.find((m) => m.slug === 'ryan-nisay') ?? null;

const pressLogos: Record<string, string> = {
  WTOP: '/assets/press/wtop.svg',
  'LOUDOUN NOW': '/assets/press/loudoun-now.svg',
  'INSIDE NOVA': '/assets/press/insidenova.svg',
  'NEWS SPRY': '/assets/press/newsspry.svg',
};

const stats = [
  { value: home?.statsAcresCleaned?.toLocaleString() ?? '3,122', label: 'Acres Cleaned' },
  { value: home?.statsMembers?.toLocaleString() ?? '270', label: 'Members' },
  { value: home?.statsImpressions?.toLocaleString() ?? '726,022', label: 'Impressions' },
  { value: home?.statsPartners?.toLocaleString() ?? '17', label: 'Partner Parks & Schools' },
];

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Loudoun Nature Conservation Project',
  url: 'https://loudounnatureconservation.org',
  logo: 'https://loudounnatureconservation.org/assets/lncp-logo.png',
  foundingDate: '2024',
  description: 'A student-led 501(c)(3) nonprofit advancing sustainability and ecological health across Loudoun County, Virginia.',
  email: 'directors@loudounnatureconservation.org',
};
---

<Base
  title="Home"
  description="Loudoun Nature Conservation Project - A student-led 501(c)(3) nonprofit empowering youth, restoring nature, and fostering community through environmental stewardship in Loudoun County, Virginia."
  jsonLd={orgJsonLd}
>
  <!-- Hero: full viewport, video background, founder quote strip pinned to bottom -->
  <section class="relative h-screen flex flex-col overflow-hidden bg-[#0d2118]" aria-label="Hero">
    <!-- Video - full bleed, no opacity tint (gradient handles contrast) -->
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster="/assets/hero-poster.jpg"
      aria-hidden="true"
    >
      <source src="/assets/hero.mp4" type="video/mp4" />
    </video>

    <!-- Gradient: lighter center for readability, strong dark at bottom for quote strip -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/35 to-black/80 pointer-events-none" aria-hidden="true"></div>

    <!-- Main content - grows to fill available space, centers text vertically -->
    <div class="relative z-10 flex-1 flex items-center justify-center px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl w-full text-center text-white">
        <p class="text-[#74c69d] font-semibold text-sm uppercase tracking-widest mb-5">
          Loudoun Nature Conservation Project
        </p>
        <h1 class="font-display font-black text-4xl sm:text-6xl lg:text-7xl leading-tight mb-6">
          {home?.heroHeadline ?? 'Youth unite for Earth; inspire change piece by piece'}
        </h1>
        <p class="text-base sm:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
          {home?.heroSubtext ?? 'Made by Students, for Students. Young hearts, green minds, hands-on action — empowering youth, restoring nature, and fostering community through non-profit (501c3) environmental stewardship in Loudoun County, Virginia.'}
        </p>
        <a
          href="/volunteer/"
          class="inline-flex items-center gap-2 px-10 py-4 rounded-lg font-bold text-lg bg-[#52b788] text-[#0d2118] hover:bg-[#74c69d] transition-colors shadow-xl"
        >
          Join Now
        </a>
      </div>
    </div>

    <!-- Founder quote strip - pinned to bottom of hero -->
    {ryan && (
      <div class="relative z-10 border-t border-white/10 bg-black/40 backdrop-blur-sm px-4 sm:px-8 py-4">
        <div class="max-w-4xl mx-auto flex items-center gap-4">
          {ryan.entry.headshot ? (
            <img
              src={ryan.entry.headshot}
              alt={ryan.entry.name}
              width="48"
              height="48"
              class="w-12 h-12 rounded-full object-cover ring-2 ring-[#52b788] shrink-0"
              loading="eager"
            />
          ) : (
            <div
              class="w-12 h-12 rounded-full bg-[#1B4332] ring-2 ring-[#52b788] shrink-0 flex items-center justify-center text-white font-bold text-sm"
              aria-hidden="true"
            >
              RN
            </div>
          )}
          <div class="min-w-0">
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
              <span class="text-white font-bold text-sm">{ryan.entry.name}</span>
              <span class="text-[#74c69d] text-xs">{ryan.entry.role}</span>
            </div>
            <p class="text-white/75 text-sm italic mt-0.5 line-clamp-2">
              "{home?.founderQuote ?? 'LNCP was born from a simple belief - students don\'t have to wait to protect our environment. We can lead that change right now, in our own community.'}"
            </p>
          </div>
        </div>
      </div>
    )}
  </section>

  <!-- Stats bar -->
  <section class="bg-[#1B4332] py-10" aria-label="Impact statistics">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        {stats.map(({ value, label }) => (
          <div>
            <dt class="text-[#74c69d] font-display font-black text-3xl sm:text-4xl">{value}</dt>
            <dd class="text-green-200 text-xs uppercase tracking-wide mt-1">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20 bg-[#f0faf4]" aria-labelledby="mission-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-[#40916C] font-semibold text-sm uppercase tracking-widest text-center mb-4">Conservation</p>
      <h2 id="mission-heading" class="font-display font-black text-3xl sm:text-4xl text-center text-[#1B4332] mb-4">
        {home?.missionHeading ?? 'The deliberate act of preserving, protecting, and restoring our natural environment for the benefit of future generations.'}
      </h2>
      <p class="text-gray-600 text-base sm:text-lg leading-relaxed text-center max-w-3xl mx-auto mb-8">
        {home?.missionBody ?? 'Loudoun Nature Conservation Project is a student-led nonprofit working to advance sustainability and ecological health across Loudoun County. We engage our community through education, hands-on restoration, and advocacy, empowering young people to become lifelong stewards of the environment.'}
      </p>
      <div class="text-center">
        <a
          href="/about/"
          class="inline-flex items-center gap-2 text-[#2D6A4F] font-semibold hover:text-[#1B4332] transition-colors"
        >
          Learn more about our mission
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Team -->
  {featuredTeam.length > 0 && (
    <section class="py-20 bg-white" aria-labelledby="team-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-[#40916C] font-semibold text-sm uppercase tracking-widest mb-2">Meet Our Team</p>
          <h2 id="team-heading" class="font-display font-black text-3xl sm:text-4xl text-[#1B4332]">Leading Staff</h2>
          <p class="text-gray-500 mt-3 max-w-2xl mx-auto text-sm sm:text-base">
            Our staff is made up of passionate student leaders dedicated to environmental advocacy and community engagement. Hover or tap a card to learn more.
          </p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
          {featuredTeam.map((member) => (
            <FlipCard
              name={member.entry.name}
              role={member.entry.role}
              bio={member.entry.bio}
              headshot={member.entry.headshot}
              email={member.entry.email ?? undefined}
              instagram={member.entry.instagram ?? undefined}
              linkedin={member.entry.linkedin ?? undefined}
              accentColor="#1B4332"
            />
          ))}
        </div>
        <div class="text-center mt-10">
          <a
            href="/team/"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[#1B4332] text-white font-semibold hover:bg-[#2D6A4F] transition-colors"
          >
            View full team
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Press -->
  <section class="py-16 bg-[#f0faf4]" aria-labelledby="press-heading">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="press-heading" class="font-display font-bold text-center text-[#1B4332] text-lg mb-8 uppercase tracking-widest">
        News on Loudoun Nature Conservation Project
      </h2>
      <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
        {(home?.pressLinks ?? [
          { publication: 'WTOP', headline: 'Coverage on WTOP', url: '#' },
          { publication: 'Loudoun Now', headline: 'Coverage in Loudoun Now', url: '#' },
          { publication: 'InsideNOVA', headline: 'Coverage on InsideNOVA', url: '#' },
          { publication: 'News Spry', headline: 'Coverage on News Spry', url: '#' },
        ]).map((link) => (
          <a
            href={link.url}
            class="text-[#1B4332] font-display font-black text-lg sm:text-2xl hover:text-[#40916C] transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            title={link.headline}
          >
            {link.publication.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[#1B4332] text-center" aria-labelledby="cta-heading">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 id="cta-heading" class="font-display font-black text-3xl sm:text-4xl text-white mb-4">
        Ready to make a difference?
      </h2>
      <p class="text-green-200 text-base mb-8">
        Join hundreds of students already protecting Loudoun County's natural spaces. Volunteer, collaborate, or reach out.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/volunteer/"
          class="px-8 py-3.5 rounded-lg font-bold bg-[#52b788] text-[#0d2118] hover:bg-[#74c69d] transition-colors"
        >
          Volunteer Now
        </a>
        <a
          href="/contact/"
          class="px-8 py-3.5 rounded-lg font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Base>
