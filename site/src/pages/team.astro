---
import Base from '@/layouts/Base.astro';
import FlipCard from '@/components/FlipCard.astro';
import BranchCard from '@/components/BranchCard.astro';
import reader from '@/lib/reader';

const allMembers = await reader.collections.teamMembers.all();
const allBranches = await reader.collections.branches.all();

const bySection = {
  executive:      allMembers.filter((m) => m.entry.section === 'executive').sort((a, b) => (a.entry.sortOrder ?? 99) - (b.entry.sortOrder ?? 99)),
  directors:      allMembers.filter((m) => m.entry.section === 'directors').sort((a, b) => (a.entry.sortOrder ?? 99) - (b.entry.sortOrder ?? 99)),
  executiveStaff: allMembers.filter((m) => m.entry.section === 'executiveStaff').sort((a, b) => (a.entry.sortOrder ?? 99) - (b.entry.sortOrder ?? 99)),
  branchPresidents: allMembers.filter((m) => m.entry.section === 'branchPresidents').sort((a, b) => (a.entry.sortOrder ?? 99) - (b.entry.sortOrder ?? 99)),
  branchStaff:    allMembers.filter((m) => m.entry.section === 'branchStaff').sort((a, b) => (a.entry.sortOrder ?? 99) - (b.entry.sortOrder ?? 99)),
};

function getBranchFor(member: (typeof allMembers)[0]) {
  if (!member.entry.branch) return null;
  return allBranches.find((b) => b.slug === member.entry.branch) ?? null;
}

function schoolInitials(name: string) {
  return name.split(/\s+/).filter(Boolean).map((w) => w[0]).join('').toUpperCase().slice(0, 3);
}

const ACCENT = '#1B4332';

const personJsonLd = allMembers.map((m) => ({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: m.entry.name,
  jobTitle: m.entry.role,
  worksFor: {
    '@type': 'Organization',
    name: 'Loudoun Nature Conservation Project',
  },
  ...(m.entry.email ? { email: m.entry.email } : {}),
  ...(m.entry.linkedin ? { sameAs: m.entry.linkedin } : {}),
}));
---

<Base
  title="Team"
  description="Meet the student leaders of Loudoun Nature Conservation Project - our executive team, directors, executive staff, and branch presidents driving conservation across Loudoun County."
  jsonLd={personJsonLd}
>
  <!-- Page header -->
  <div class="bg-paper border-b hairline py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-display italic text-clay text-lg mb-4">Who We Are</p>
      <h1 class="font-display font-medium text-4xl sm:text-5xl text-ink">Our Team</h1>
      <p class="mt-5 text-ink-soft max-w-2xl mx-auto">
        Hover or tap any card to learn more about a team member. All members are student volunteers dedicated to conservation.
      </p>
    </div>
  </div>

  {/* ---- EXECUTIVE ---- */}
  {bySection.executive.length > 0 && (
    <section aria-labelledby="exec-heading" class="py-16 bg-paper">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="mb-10 text-center">
          <h2 id="exec-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink">Executive</h2>
        </header>
        <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
          {bySection.executive.map((m) => (
            <div class="w-[calc(50%-0.5rem)] sm:w-56 lg:w-64">
              <FlipCard
                name={m.entry.name}
                role={m.entry.role}
                bio={m.entry.bio}
                headshot={m.entry.headshot}
                email={m.entry.email ?? undefined}
                instagram={m.entry.instagram ?? undefined}
                linkedin={m.entry.linkedin ?? undefined}
                accentColor={ACCENT}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ---- DIRECTORS ---- */}
  {bySection.directors.length > 0 && (
    <section aria-labelledby="directors-heading" class="py-16 bg-paper-2 border-y hairline">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="mb-10 text-center">
          <h2 id="directors-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink">Directors</h2>
        </header>
        <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
          {bySection.directors.map((m) => (
            <div class="w-[calc(50%-0.5rem)] sm:w-56 lg:w-64">
              <FlipCard
                name={m.entry.name}
                role={m.entry.role}
                bio={m.entry.bio}
                headshot={m.entry.headshot}
                email={m.entry.email ?? undefined}
                instagram={m.entry.instagram ?? undefined}
                linkedin={m.entry.linkedin ?? undefined}
                accentColor={ACCENT}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ---- EXECUTIVE STAFF (accordion) ---- */}
  {bySection.executiveStaff.length > 0 && (
    <section aria-labelledby="exec-staff-heading" class="py-2 bg-paper border-b hairline">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <details class="group">
          <summary class="flex items-center justify-between gap-4 py-6 cursor-pointer list-none">
            <h2 id="exec-staff-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink">Executive Staff</h2>
            <svg
              class="w-6 h-6 text-ink-soft transition-transform group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="pb-14">
            <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
              {bySection.executiveStaff.map((m) => (
                <div class="w-[calc(50%-0.5rem)] sm:w-56 lg:w-64">
                  <FlipCard
                    name={m.entry.name}
                    role={m.entry.role}
                    bio={m.entry.bio}
                    headshot={m.entry.headshot}
                    email={m.entry.email ?? undefined}
                    instagram={m.entry.instagram ?? undefined}
                    linkedin={m.entry.linkedin ?? undefined}
                    accentColor={ACCENT}
                  />
                </div>
              ))}
            </div>
          </div>
        </details>
      </div>
    </section>
  )}

  {/* ---- BRANCH PRESIDENTS ---- */}
  {bySection.branchPresidents.length > 0 && (
    <section id="branches" aria-labelledby="branch-presidents-heading" class="py-16 bg-paper-2 border-b hairline">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="mb-4 text-center">
          <h2 id="branch-presidents-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink">Branch Presidents</h2>
        </header>
        <p class="text-ink-soft text-sm mb-10 text-center max-w-2xl mx-auto">
          Each branch president leads LNCP operations at their school or college - organizing cleanups, recruiting members, and representing their community.
        </p>
        <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
          {bySection.branchPresidents.map((m) => {
            const branch = getBranchFor(m);
            return (
              <div class="w-[calc(50%-0.5rem)] sm:w-56 lg:w-64">
                <BranchCard
                  presidentName={m.entry.name}
                  presidentRole={m.entry.role}
                  presidentBio={m.entry.bio}
                  presidentHeadshot={m.entry.headshot}
                  presidentEmail={m.entry.email ?? undefined}
                  presidentInstagram={m.entry.instagram ?? undefined}
                  presidentLinkedin={m.entry.linkedin ?? undefined}
                  branchName={branch?.entry.name ?? m.entry.branch ?? 'Branch'}
                  schoolLogo={branch?.entry.schoolLogo ?? undefined}
                  schoolInitials={branch ? schoolInitials(branch.entry.school) : undefined}
                />
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* ---- BRANCH STAFF ---- */}
  {bySection.branchStaff.length > 0 && (
    <section aria-labelledby="branch-staff-heading" class="py-16 bg-paper">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="mb-4 text-center">
          <h2 id="branch-staff-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink">Branch Staff</h2>
        </header>
        <p class="text-ink-soft text-sm mb-10 text-center max-w-2xl mx-auto">
          Branch staff serve as vice presidents, operations leads, outreach leads, and general members within their school chapters.
        </p>
        <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
          {bySection.branchStaff.map((m) => (
            <div class="w-[calc(50%-0.5rem)] sm:w-56 lg:w-64">
              <FlipCard
                name={m.entry.name}
                role={m.entry.role}
                bio={m.entry.bio}
                headshot={m.entry.headshot}
                email={m.entry.email ?? undefined}
                instagram={m.entry.instagram ?? undefined}
                linkedin={m.entry.linkedin ?? undefined}
                accentColor={ACCENT}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Empty state */}
  {Object.values(bySection).every((s) => s.length === 0) && (
    <div class="py-32 text-center text-ink-soft">
      <p class="font-display text-xl">Team roster coming soon.</p>
      <p class="text-sm mt-2">Check back shortly or <a href="/contact/" class="text-forest-800 hover:underline">contact us</a>.</p>
    </div>
  )}
</Base>
