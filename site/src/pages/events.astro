---
import Base from '@/layouts/Base.astro';
import reader from '@/lib/reader';

const events = await reader.collections.events.all();
const now = new Date();
const upcoming = events
  .filter((e) => e.entry.date && new Date(e.entry.date) >= now)
  .sort((a, b) => new Date(a.entry.date!).getTime() - new Date(b.entry.date!).getTime());
const past = events
  .filter((e) => e.entry.date && new Date(e.entry.date) < now)
  .sort((a, b) => new Date(b.entry.date!).getTime() - new Date(a.entry.date!).getTime());
---

<Base
  title="Events"
  description="Upcoming and past events from Loudoun Nature Conservation Project - cleanups, restoration events, workshops, and volunteer opportunities in Loudoun County, Virginia."
>
  <div class="bg-paper border-b hairline py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-display italic text-clay text-lg mb-4">Get Involved</p>
      <h1 class="font-display font-medium text-4xl sm:text-5xl text-ink">Events</h1>
    </div>
  </div>

  <section class="py-20 bg-paper-2 border-b hairline" aria-labelledby="upcoming-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="upcoming-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink mb-10">Upcoming Events</h2>

      {upcoming.length > 0 ? (
        <ol class="space-y-4" role="list">
          {upcoming.map((event) => {
            const date = new Date(event.entry.date!);
            const displayDate = date.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
            return (
              <li class="bg-paper border hairline p-6 flex flex-col sm:flex-row gap-5">
                <div class="shrink-0 text-center bg-forest-900 text-paper p-3 w-16 h-fit">
                  <p class="text-xs uppercase tracking-wide">{date.toLocaleDateString('en-US', { month: 'short' })}</p>
                  <p class="font-display text-2xl leading-none mt-0.5">{date.getDate()}</p>
                </div>
                <div class="flex-1">
                  <h3 class="font-display font-medium text-ink text-xl">{event.entry.title}</h3>
                  <p class="text-ink-soft text-sm mt-1">
                    {displayDate}
                    {event.entry.location && ` · ${event.entry.location}`}
                  </p>
                  {event.entry.description && (
                    <p class="text-ink-soft text-sm mt-3 leading-relaxed">{event.entry.description}</p>
                  )}
                  {event.entry.signupLink && (
                    <a
                      href={event.entry.signupLink}
                      class="inline-block mt-4 px-5 py-2.5 bg-forest-900 text-paper text-sm font-semibold hover:bg-forest-800 transition-colors"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Sign Up / RSVP
                    </a>
                  )}
                </div>
              </li>
            );
          })}
        </ol>
      ) : (
        <div class="bg-paper border hairline p-12 text-center">
          <h3 class="font-display font-medium text-xl text-ink mb-3">No upcoming events right now</h3>
          <p class="text-ink-soft text-sm max-w-md mx-auto">
            We're planning our next cleanup - check back soon, or follow us on Instagram for the latest announcements.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-5">
            <a
              href="https://instagram.com/loudounncp"
              class="px-6 py-3 bg-forest-900 text-paper text-sm font-semibold hover:bg-forest-800 transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              Follow on Instagram
            </a>
            <a
              href="/volunteer/"
              class="text-sm text-ink border-b border-ink pb-0.5 hover:text-ink-soft hover:border-ink-soft transition-colors"
            >
              Stay in touch
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  {past.length > 0 && (
    <section class="py-16 bg-paper" aria-labelledby="past-heading">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="past-heading" class="font-display font-medium text-2xl text-ink mb-8">Past Events</h2>
        <ol class="divide-y hairline border-y hairline" role="list">
          {past.map((event) => {
            const date = new Date(event.entry.date!);
            const displayDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
            return (
              <li class="flex items-start gap-4 py-4">
                <time class="text-xs text-ink-soft shrink-0 mt-0.5 w-28">{displayDate}</time>
                <div>
                  <p class="font-semibold text-sm text-ink">{event.entry.title}</p>
                  {event.entry.location && <p class="text-xs text-ink-soft mt-0.5">{event.entry.location}</p>}
                </div>
              </li>
            );
          })}
        </ol>
      </div>
    </section>
  )}
</Base>
