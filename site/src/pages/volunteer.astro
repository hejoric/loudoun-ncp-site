---
import Base from '@/layouts/Base.astro';
import reader from '@/lib/reader';

const settings = await reader.singletons.siteSettings.read();
const formUrl = settings?.volunteerFormUrl ?? null;

const reasons = [
  { title: 'Real Impact', body: 'We\'ve cleaned 3,122 acres and counting. Every cleanup makes a measurable difference in Loudoun County.' },
  { title: 'Student-Led', body: 'Every role is led by students - for students. Build leadership skills, earn service hours, and make connections.' },
  { title: 'Community', body: 'Join a network of 270+ members across our school and college branches.' },
];
---

<Base
  title="Volunteer"
  description="Volunteer with Loudoun Nature Conservation Project - join student-led cleanups, restoration events, and conservation efforts across Loudoun County, Virginia."
>
  <div class="bg-paper border-b hairline py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-display italic text-clay text-lg mb-4">Join the Movement</p>
      <h1 class="font-display font-medium text-4xl sm:text-5xl text-ink">Volunteer</h1>
      <p class="mt-5 text-ink-soft max-w-xl mx-auto">
        Young hearts, green minds, hands-on action. Join hundreds of student volunteers already protecting Loudoun County's natural spaces.
      </p>
    </div>
  </div>

  <!-- Why volunteer -->
  <section class="py-20 bg-paper-2 border-b hairline">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Why Volunteer With Us?</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 border-t border-l hairline">
        {reasons.map(({ title, body }, i) => (
          <div class="bg-paper border-r border-b hairline p-8">
            <p class="font-display italic text-clay text-sm mb-3">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="font-display font-medium text-ink text-xl mb-3">{title}</h3>
            <p class="text-ink-soft text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Form -->
  <section class="py-20 bg-paper" aria-labelledby="form-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Sign Up</p>
      <h2 id="form-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink mb-3">Sign up to volunteer</h2>
      <p class="text-ink-soft text-sm mb-10">Fill out the form below and we'll connect you with your nearest branch.</p>

      {formUrl ? (
        <div class="overflow-hidden border hairline">
          <iframe
            src={formUrl}
            width="100%"
            height="800"
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            title="LNCP Volunteer Sign-Up Form"
            loading="lazy"
            class="w-full"
          >
            Loading form...
          </iframe>
        </div>
      ) : (
        <div class="bg-paper-2 border hairline p-10 text-center">
          <p class="text-ink mb-4">Volunteer sign-up form coming soon.</p>
          <p class="text-sm text-ink-soft">
            In the meantime, email us at{' '}
            <a href="mailto:directors@loudounnatureconservation.org" class="text-forest-800 border-b border-forest-800 pb-0.5 hover:text-forest-900 font-medium">
              directors@loudounnatureconservation.org
            </a>
          </p>
        </div>
      )}
    </div>
  </section>
</Base>
