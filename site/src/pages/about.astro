---
import Base from '@/layouts/Base.astro';
import reader from '@/lib/reader';

const about = await reader.singletons.about.read();

const timeline = about?.historyTimeline?.length
  ? about.historyTimeline
  : [
      { year: 'April 2024', event: 'Loudoun Nature Conservation Project incorporated in Virginia as a 501(c)(3) nonprofit. Founded by Ryan Nisay with co-founders Christian Shire and Carter Lepuil.' },
      { year: 'Summer 2024', event: 'LNCP holds its first community cleanups across Loudoun County, partnering with local parks and schools.' },
      { year: 'Fall 2024', event: 'First school branches launched at Potomac Falls High School and other Loudoun schools. Research division established with first water quality study.' },
      { year: 'Winter 2024', event: 'First research publication: "Water Health: Testing and Determining Health of Local Bodies of Water" (Shire & Nisay, Dec 2024).' },
      { year: '2025', event: 'Expanded to seven school and college branches including Independence, Dominion, Rock Ridge, Stone Bridge, NOVA, and GMU. Multiple research papers published on dissolved oxygen and agricultural runoff.' },
      { year: '2026', event: 'LNCP surpasses 270 members, 3,122 acres cleaned, and 726,000+ social media impressions. New branch leadership structure established with Alyssa Nisay (Potomac Falls), expanded director team, and five active research publications.' },
    ];

const whatWeDo = about?.whatWeDo?.length
  ? about.whatWeDo
  : [
      {
        heading: 'Community Cleanups',
        body: 'We organize regular cleanups across Loudoun County parks, trails, and waterways. From neighborhood streams to county-wide events, our volunteers work hands-on to restore natural spaces.',
      },
      {
        heading: 'Student Research',
        body: 'Our research division conducts original environmental science studies - investigating water quality, dissolved oxygen, nutrient runoff, and ecosystem health - and publishes findings for public access.',
      },
      {
        heading: 'Education & Outreach',
        body: 'We empower the next generation of conservation leaders through school chapters, workshops, and community engagement events that connect students to the natural world around them.',
      },
      {
        heading: 'Policy & Advocacy',
        body: 'By partnering with local parks, schools, and organizations, we amplify our impact and help shape environmental stewardship culture across Northern Virginia.',
      },
    ];
---

<Base
  title="About"
  description="Learn about Loudoun Nature Conservation Project - our mission, what we do, our impact, and the history of this student-led 501(c)(3) nonprofit in Loudoun County, Virginia."
>
  <!-- Page header -->
  <div class="bg-[#1B4332] text-white py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-[#74c69d] text-sm uppercase tracking-widest font-semibold mb-3">Who We Are</p>
      <h1 class="font-display font-black text-4xl sm:text-5xl">About LNCP</h1>
    </div>
  </div>

  <!-- Mission -->
  <section class="py-16 bg-white" aria-labelledby="mission-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="mission-heading" class="font-display font-bold text-2xl text-[#1B4332] mb-6 flex items-center gap-3">
        <span class="w-8 h-0.5 bg-[#52b788] shrink-0" aria-hidden="true"></span>
        Our Mission
      </h2>
      <p class="text-gray-700 text-lg leading-relaxed">
        {about?.mission ?? 'Loudoun Nature Conservation Project is a student-led nonprofit working to advance sustainability and ecological health across Loudoun County. We engage our community through education, hands-on restoration, and advocacy, empowering young people to become lifelong stewards of the environment. Through local cleanups, habitat restoration, and outreach events, we work to restore ecosystems and build a lasting culture of environmental responsibility. Made by students, for students, we\'re proving that the next generation of conservation leaders is already at work.'}
      </p>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-16 bg-[#f0faf4]" aria-labelledby="what-we-do-heading">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="what-we-do-heading" class="font-display font-bold text-2xl text-[#1B4332] mb-10 flex items-center gap-3">
        <span class="w-8 h-0.5 bg-[#52b788] shrink-0" aria-hidden="true"></span>
        What We Do
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {whatWeDo.map((item) => (
          <div class="bg-white rounded-xl p-6 border border-[#d8f3dc] shadow-sm">
            <h3 class="font-display font-bold text-[#1B4332] text-base mb-2">{item.heading}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Impact -->
  <section class="py-16 bg-[#1B4332] text-white" aria-labelledby="impact-heading">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="impact-heading" class="font-display font-bold text-2xl mb-10">Our Impact</h2>
      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-8">
        {(about?.impactStats?.length ? about.impactStats : [
          { value: '3,122', label: 'Acres Cleaned' },
          { value: '270', label: 'Members' },
          { value: '726,022', label: 'Impressions' },
          { value: '17', label: 'Partner Parks & Schools' },
        ]).map(({ value, label }) => (
          <div>
            <dt class="text-[#74c69d] font-display font-black text-3xl sm:text-4xl">{value}</dt>
            <dd class="text-green-200 text-xs uppercase tracking-wide mt-1">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- History Timeline -->
  <section id="history" class="py-16 bg-white" aria-labelledby="history-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="history-heading" class="font-display font-bold text-2xl text-[#1B4332] mb-10 flex items-center gap-3">
        <span class="w-8 h-0.5 bg-[#52b788] shrink-0" aria-hidden="true"></span>
        Our History
      </h2>
      <ol class="relative border-l-2 border-[#d8f3dc] space-y-8 pl-6">
        {timeline.map((entry) => (
          <li class="relative">
            <span
              class="absolute -left-[1.85rem] top-1 w-4 h-4 rounded-full bg-[#52b788] border-2 border-white shadow"
              aria-hidden="true"
            ></span>
            <time class="text-[#40916C] font-display font-semibold text-sm">{entry.year}</time>
            <p class="mt-1 text-gray-600 text-sm leading-relaxed">{entry.event}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Press -->
  <section class="py-16 bg-[#f0faf4]" aria-labelledby="press-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="press-heading" class="font-display font-bold text-2xl text-[#1B4332] mb-6 flex items-center gap-3">
        <span class="w-8 h-0.5 bg-[#52b788] shrink-0" aria-hidden="true"></span>
        Press Coverage
      </h2>
      <p class="text-gray-600 text-sm mb-6">
        LNCP has been covered by regional media outlets. See links below for articles featuring our work.
      </p>
      <div class="flex flex-wrap gap-3">
        {['WTOP', 'Loudoun Now', 'InsideNOVA', 'News Spry'].map((pub) => (
          <span class="px-4 py-2 rounded-full bg-[#1B4332] text-white font-display font-semibold text-sm">
            {pub}
          </span>
        ))}
      </div>
      <p class="mt-4 text-xs text-gray-400 italic">Press links coming soon. Contact us for press inquiries.</p>
    </div>
  </section>
</Base>
