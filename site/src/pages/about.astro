---
import Base from '@/layouts/Base.astro';
import reader from '@/lib/reader';

const about = await reader.singletons.about.read();
const home = await reader.singletons.home.read();

const timeline = about?.historyTimeline?.length
  ? about.historyTimeline
  : [
      { year: 'April 2024', event: 'Loudoun Nature Conservation Project incorporated in Virginia as a 501(c)(3) nonprofit. Founded by Ryan Nisay with co-founders Christian Shire and Carter Lepuil.' },
      { year: 'Summer 2024', event: 'LNCP holds its first community cleanups across Loudoun County, partnering with local parks and schools.' },
      { year: 'Fall 2024', event: 'First school branches launched at Potomac Falls High School and other Loudoun schools. Research division established with first water quality study.' },
      { year: 'Winter 2024', event: 'First research publication: "Water Health: Testing and Determining Health of Local Bodies of Water" (Shire & Nisay, Dec 2024).' },
      { year: '2025', event: 'Expanded to seven school and college branches including Independence, Dominion, Rock Ridge, Stone Bridge, NOVA, and GMU. Multiple research papers published on dissolved oxygen and agricultural runoff.' },
      { year: '2026', event: 'LNCP surpasses 270 members, 3,122 acres cleaned, and 726,000+ social media impressions. Recognized in the United States Congressional Record by Representative Suhas Subramanyam of Virginia\'s 10th District. New branches announced for the upcoming school year.' },
    ];

const whatWeDo = about?.whatWeDo?.length
  ? about.whatWeDo
  : [
      {
        heading: 'Community Cleanups',
        body: 'We organize regular cleanups across Loudoun County parks, trails, and waterways. From neighborhood streams to county-wide events, our volunteers work hands-on to restore natural spaces.',
      },
      {
        heading: 'Student Research',
        body: 'Our research division conducts original environmental science studies - investigating water quality, dissolved oxygen, nutrient runoff, and ecosystem health - and publishes findings for public access.',
      },
      {
        heading: 'Education & Outreach',
        body: 'We empower the next generation of conservation leaders through school chapters, workshops, and community engagement events that connect students to the natural world around them.',
      },
      {
        heading: 'Policy & Advocacy',
        body: 'By partnering with local parks, schools, and organizations, we amplify our impact and help shape environmental stewardship culture across Northern Virginia.',
      },
    ];

const pressLinks = home?.pressLinks ?? [];
---

<Base
  title="About"
  description="Learn about Loudoun Nature Conservation Project - our mission, what we do, our impact, and the history of this student-led 501(c)(3) nonprofit in Loudoun County, Virginia."
>
  <!-- Page header -->
  <div class="bg-paper border-b hairline py-16 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-display italic text-clay text-lg mb-4">Who We Are</p>
      <h1 class="font-display font-medium text-4xl sm:text-5xl text-ink">About LNCP</h1>
    </div>
  </div>

  <!-- Mission -->
  <section class="py-20 bg-paper" aria-labelledby="mission-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-[0.9fr_1.3fr] gap-10 md:gap-20 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Our Mission</p>
        <h2 id="mission-heading" class="font-display font-medium text-2xl sm:text-3xl leading-snug text-ink text-balance">
          Made by students, for students.
        </h2>
      </div>
      <p class="text-base sm:text-lg text-ink-soft leading-relaxed">
        {about?.mission ?? 'Loudoun Nature Conservation Project is a student-led nonprofit working to advance sustainability and ecological health across Loudoun County. We engage our community through education, hands-on restoration, and advocacy, empowering young people to become lifelong stewards of the environment. Through local cleanups, habitat restoration, and outreach events, we work to restore ecosystems and build a lasting culture of environmental responsibility. Made by students, for students, we\'re proving that the next generation of conservation leaders is already at work.'}
      </p>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-20 bg-paper-2 border-y hairline" aria-labelledby="what-we-do-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">What We Do</p>
      <h2 id="what-we-do-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink mb-12">
        Four ways we serve Loudoun County
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 border-t border-l hairline">
        {whatWeDo.map((item, i) => (
          <div class="bg-paper border-r border-b hairline p-8">
            <p class="font-display italic text-clay text-sm mb-3">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="font-display font-medium text-ink text-xl mb-3">{item.heading}</h3>
            <p class="text-ink-soft text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Impact -->
  <section class="py-20 bg-paper" aria-labelledby="impact-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Our Impact</p>
      <dl class="grid grid-cols-2 sm:grid-cols-4 border-t border-l hairline">
        {(about?.impactStats?.length ? about.impactStats : [
          { value: '3,122', label: 'Acres Cleaned' },
          { value: '270', label: 'Members' },
          { value: '726,022', label: 'Impressions' },
          { value: '17', label: 'Partner Parks & Schools' },
        ]).map(({ value, label }) => (
          <div class="border-r border-b hairline p-6 sm:p-8">
            <dt class="sr-only">{label}</dt>
            <dd class="font-display text-3xl sm:text-4xl text-forest-900">{value}</dd>
            <dd class="text-xs uppercase tracking-wider text-ink-soft mt-2">{label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- History Timeline -->
  <section id="history" class="py-20 bg-paper-2 border-y hairline" aria-labelledby="history-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Our History</p>
      <h2 id="history-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink mb-12">
        From one park to a county-wide movement
      </h2>
      <ol class="relative border-l hairline space-y-10 pl-8">
        {timeline.map((entry) => (
          <li class="relative">
            <span
              class="absolute -left-[2.28rem] top-1.5 w-2.5 h-2.5 rounded-full bg-forest-900"
              aria-hidden="true"
            ></span>
            <time class="font-display italic text-clay text-base">{entry.year}</time>
            <p class="mt-2 text-ink-soft text-sm leading-relaxed">{entry.event}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Press -->
  <section class="py-20 bg-paper" aria-labelledby="press-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-clay mb-5">Press Coverage</p>
      <h2 id="press-heading" class="font-display font-medium text-2xl sm:text-3xl text-ink mb-10">
        In the news
      </h2>
      {pressLinks.length > 0 ? (
        <ul class="divide-y hairline border-y hairline" role="list">
          {pressLinks.map((link) => (
            <li>
              <a
                href={link.url}
                class="group flex items-baseline justify-between gap-6 py-5 hover:bg-paper-2 transition-colors px-2 -mx-2"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span>
                  <span class="block font-display text-lg text-ink group-hover:text-forest-900 transition-colors">{link.publication}</span>
                  <span class="block text-sm text-ink-soft mt-1">{link.headline}</span>
                </span>
                <span class="text-ink-soft shrink-0" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-ink-soft text-sm">Contact us for press inquiries.</p>
      )}
    </div>
  </section>
</Base>
