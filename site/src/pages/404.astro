---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Page Not Found"
  description="The page you're looking for doesn't exist - Loudoun Nature Conservation Project"
>
  <div class="min-h-[70vh] flex items-center justify-center bg-paper px-4">
    <div class="text-center max-w-md">
      <p class="font-display italic text-clay text-7xl mb-6" aria-hidden="true">404</p>
      <h1 class="font-display font-medium text-3xl text-ink mb-4">Page Not Found</h1>
      <p class="text-ink-soft text-sm mb-10">
        This path seems to have gone back to nature. The page you're looking for doesn't exist or may have moved.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
        <a
          href="/"
          class="px-6 py-3 bg-forest-900 text-paper font-semibold text-sm hover:bg-forest-800 transition-colors"
        >
          Go Home
        </a>
        <a
          href="/contact/"
          class="text-sm text-ink border-b border-ink pb-0.5 hover:text-ink-soft hover:border-ink-soft transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </div>
</Base>
