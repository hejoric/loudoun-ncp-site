---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Page Not Found"
  description="The page you're looking for doesn't exist - Loudoun Nature Conservation Project"
>
  <div class="min-h-[70vh] flex items-center justify-center bg-[#f0faf4] px-4">
    <div class="text-center max-w-md">
      <p class="font-display font-black text-[#52b788] text-8xl mb-4" aria-hidden="true">404</p>
      <h1 class="font-display font-black text-2xl text-[#1B4332] mb-3">Page Not Found</h1>
      <p class="text-gray-600 text-sm mb-8">
        This path seems to have gone back to nature. The page you're looking for doesn't exist or may have moved.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="px-6 py-3 rounded-lg bg-[#1B4332] text-white font-semibold text-sm hover:bg-[#2D6A4F] transition-colors"
        >
          Go Home
        </a>
        <a
          href="/contact/"
          class="px-6 py-3 rounded-lg border border-[#1B4332] text-[#1B4332] font-semibold text-sm hover:bg-[#d8f3dc] transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </div>
</Base>
